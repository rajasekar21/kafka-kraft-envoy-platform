global_defs {
    router_id {{ inventory_hostname }}
    enable_script_security
}

vrrp_script chk_envoy {
    script "/usr/bin/curl -sf http://127.0.0.1:9901/ready"
    interval 3
    weight   -20
    fall     2
    rise     2
}

vrrp_instance KAFKA_VIP {
    state       {% if inventory_hostname == groups['envoy'][0] %}MASTER{% else %}BACKUP{% endif %}

    interface   {{ ansible_default_ipv4.interface }}
    virtual_router_id 51
    priority    {{ priority }}
    advert_int  1

    authentication {
        auth_type PASS
        auth_pass kafka-ha
    }

    virtual_ipaddress {
        {{ vip }}/24
    }

    track_script {
        chk_envoy
    }

    notify_master "/bin/systemctl restart envoy"
}
